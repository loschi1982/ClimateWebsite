# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Was ist diese Datei?
# Vorlage für deine lokale .env-Datei mit Passwörtern, Adressen
# und API-Schlüsseln. Die .env wird NICHT in Git eingecheckt.
#
# So verwendest du diese Datei:
#   cp .env.example .env
#   # Dann .env öffnen und Werte anpassen (wo nötig)
#
# Für den lokalen Start mit Docker Compose reichen die Standardwerte!
# Nur die API-Schlüssel (NASA, NOAA, Anthropic) musst du eintragen
# wenn du echte Daten abrufen möchtest.
#
# Team: Developer Setup Team | Branch: feature/developer-setup
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# TIMESCALEDB (ADR-001: Zeitreihendatenbank)
# ══════════════════════════════════════════════════════════════════════════════

# DATABASE_URL: Verbindungsstring für das API Gateway (im Docker-Netzwerk)
# Format: postgresql://BENUTZER:PASSWORT@HOST:PORT/DATENBANKNAME
# "db" = Name des TimescaleDB-Containers (Docker löst das automatisch auf)
DATABASE_URL=postgresql://climateinsight:password@db:5432/climateinsight

# DATABASE_URL_DIRECT: Für externe DB-Tools (DBeaver, pgAdmin, psql)
# Zugriff von deinem Computer (nicht aus dem Container) → localhost statt "db"
DATABASE_URL_DIRECT=postgresql://climateinsight:password@localhost:5432/climateinsight

# Zugangsdaten (müssen mit docker-compose.yml übereinstimmen!)
POSTGRES_USER=climateinsight
POSTGRES_PASSWORD=password
POSTGRES_DB=climateinsight


# ══════════════════════════════════════════════════════════════════════════════
# REDIS (Cache + Celery Task Queue)
# ══════════════════════════════════════════════════════════════════════════════

# REDIS_URL: Verbindung für den API Gateway und Celery-Worker
# Datenbank 0 = Celery-Jobs und API-Cache
# (Offene Frage oq_003: Celery vs. FastAPI Background Tasks – noch offen)
REDIS_URL=redis://redis:6379/0

# Wie lange sollen Analyseergebnisse im Cache bleiben? (in Sekunden)
# 3600 = 1 Stunde
REDIS_CACHE_TTL=3600


# ══════════════════════════════════════════════════════════════════════════════
# MINIO (S3-kompatibler Objektspeicher für Rohdaten)
# ══════════════════════════════════════════════════════════════════════════════

# MinIO speichert unveränderliche Rohdaten (Projektstandard):
# Rohdaten von NASA, NOAA, Copernicus, IPCC, NSIDC (CSV, NetCDF)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=climateinsight
MINIO_SECRET_KEY=password123

# MinIO-Buckets (Ordner für verschiedene Dateitypen)
MINIO_BUCKET_CLIMATE_DATA=climate-data   # Rohdaten (CSV, NetCDF)
MINIO_BUCKET_CHARTS=charts               # Exportierte Diagramme (SVG, PNG)
MINIO_BUCKET_EXPORTS=exports             # CSV-Exporte für Nutzer

# SSL für MinIO? Für lokale Entwicklung: false
MINIO_USE_SSL=false


# ══════════════════════════════════════════════════════════════════════════════
# FASTAPI API GATEWAY
# (services/api_gateway/src/main.py)
# ══════════════════════════════════════════════════════════════════════════════

# SECRET_KEY: zum Verschlüsseln von JWT-Tokens (Auth für schreibende Endpoints)
# Generiere einen sicheren Schlüssel für die Produktion:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production-please

# DEBUG: Detaillierte Fehlermeldungen – nur für Entwicklung!
DEBUG=true

# LOG_LEVEL: Wie detailliert sollen Log-Nachrichten sein?
# Optionen: debug | info | warning | error | critical
LOG_LEVEL=debug

# API Gateway Host und Port
API_HOST=0.0.0.0
API_PORT=8000

# CORS: Welche Adressen dürfen das Backend ansprechen?
# Frontend läuft auf Port 3000, Swagger UI auf Port 8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# API-Versionierung (ADR-004: URL-Pfad-Versionierung)
# Alle Endpunkte laufen unter /api/v1/
API_VERSION=v1


# ══════════════════════════════════════════════════════════════════════════════
# NEXT.JS 15 FRONTEND (App Router)
# (frontend/src/)
# ══════════════════════════════════════════════════════════════════════════════

# NEXT_PUBLIC_API_URL: API-Adresse – sichtbar im Browser
# "NEXT_PUBLIC_" = im Browser verfügbar (für Client-Komponenten)
NEXT_PUBLIC_API_URL=http://localhost:8000

# INTERNAL_API_URL: Für Server-seitige Anfragen (Next.js Server Components)
# Nutzt den Docker-internen Namen statt localhost
INTERNAL_API_URL=http://api_gateway:8000

NODE_ENV=development
# Keine anonymen Nutzungsdaten an Vercel senden
NEXT_TELEMETRY_DISABLED=1


# ══════════════════════════════════════════════════════════════════════════════
# KLIMADATEN-QUELLEN
# (modules/data_ingestion/src/connectors/)
# ══════════════════════════════════════════════════════════════════════════════

# NASA GISS (GISTEMP v4 – globale Oberflächentemperatur seit 1880)
# DOI: 10.7289/V5MGNM48
# Kostenlos registrieren: https://api.nasa.gov/
# Für Tests: "DEMO_KEY" (stark limitiert – max. 30 Anfragen/Stunde)
# Connector: modules/data_ingestion/src/connectors/nasa_giss.py (P1-DP-02: implementiert)
NASA_API_KEY=DEMO_KEY

# NOAA GML (CO₂-Messungen Mauna Loa seit 1958)
# Token anfordern: https://www.ncdc.noaa.gov/cdo-web/token
# Connector: modules/data_ingestion/src/connectors/noaa_co2.py (P2-DP-01: geplant)
NOAA_API_TOKEN=

# Copernicus C3S (europäischer Klimadatendienst)
# Registrieren: https://cds.climate.copernicus.eu/
# Connector: modules/data_ingestion/src/connectors/copernicus.py (P2-DP-05: geplant)
COPERNICUS_API_URL=https://cds.climate.copernicus.eu/api/v2
COPERNICUS_API_KEY=

# NSIDC (Meereis- und Gletscherdaten seit 1979)
# Viele Daten ohne API-Schlüssel verfügbar
# Connector: modules/data_ingestion/src/connectors/nsidc.py (P2-DP-02: geplant)
NSIDC_API_URL=https://nsidc.org/api/

# NASA Meeresspiegel (seit 1993, Altimetrie)
# Connector: modules/data_ingestion/src/connectors/nasa_sea_level.py (P2-DP-03: geplant)
NASA_SEA_LEVEL_URL=https://sealevel.nasa.gov/


# ══════════════════════════════════════════════════════════════════════════════
# ANTHROPIC CLAUDE API
# (modules/ai_explanation/src/generator/article_generator.py)
# ══════════════════════════════════════════════════════════════════════════════

# WICHTIG: Jeder KI-generierte Artikel hat immer status: pending_review
# und wird NIEMALS automatisch veröffentlicht (ADR-003, non_negotiable: true).
# API-Schlüssel erstellen: https://console.anthropic.com/
# NIEMALS diesen Schlüssel in Git einchecken!
ANTHROPIC_API_KEY=

# Modell für die Artikelgenerierung
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximale Tokens pro Generierung (entspricht ca. 800 Wörtern Zielwortanzahl)
ANTHROPIC_MAX_TOKENS=4096

# LlamaIndex RAG-Pipeline (P2-AI-01: geplant)
# Wird für semantische Suche in der Wissensbasis verwendet
LLAMAINDEX_CHUNK_SIZE=512
LLAMAINDEX_CHUNK_OVERLAP=50


# ══════════════════════════════════════════════════════════════════════════════
# ENTWICKLUNGS-UTILITIES
# ══════════════════════════════════════════════════════════════════════════════

# SEED_DATABASE: Beispieldaten beim Start laden?
# true = Testdaten werden eingespielt (nützlich für Entwicklung)
# Lädt z.B. knowledge_seeds/ aus data/knowledge_seeds/ (P1-AI-01)
SEED_DATABASE=true

# RESET_DATABASE: Datenbank beim Start löschen und neu erstellen?
# VORSICHT: Alle Daten gehen verloren!
# Nur für Entwicklung, niemals in der Produktion!
RESET_DATABASE=false

# E-MAIL (lokale Entwicklung mit MailHog)
# MailHog fängt alle E-Mails ab statt sie wirklich zu versenden.
# Web-Oberfläche: http://localhost:8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@climateinsight.dev