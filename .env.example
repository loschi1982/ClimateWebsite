# ============================================================
# Klimaplattform – Umgebungsvariablen
# ============================================================
# Diese Datei ist eine Vorlage. Sie enthält KEINE echten Schlüssel.
#
# Anleitung:
#   1. Kopiere diese Datei: cp .env.example .env
#   2. Trage deine echten Werte in die .env-Datei ein
#   3. Committe die .env-Datei NIEMALS in Git (sie steht in .gitignore)
# ============================================================

# ------------------------------------------------------------
# Backend – Allgemein
# ------------------------------------------------------------

# Laufumgebung: "development" oder "production"
ENVIRONMENT=development

# Erlaubte Ursprünge für API-Anfragen (CORS)
# Im lokalen Betrieb ist das der Vite-Entwicklungsserver
ALLOWED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------
# KI-Integration (AI Explanation Team)
# ------------------------------------------------------------

# Anthropic API-Key für die Artikelgenerierung
# Erhalte deinen Key auf: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-dein-key-hier

# ------------------------------------------------------------
# Externe Datenquellen
# ------------------------------------------------------------

# Copernicus Climate Data Store API-Key (Phase 2)
# Kostenlose Registrierung auf: https://cds.climate.copernicus.eu/
# Leer lassen, wenn noch nicht benötigt
COPERNICUS_API_KEY=

# ------------------------------------------------------------
# Datenbank
# ------------------------------------------------------------

# Pfad zur SQLite-Datenbankdatei (relativ zum backend/-Ordner)
DATABASE_URL=sqlite:///./klimaplattform.db

# ------------------------------------------------------------
# Datenpfade
# ------------------------------------------------------------

# Ordner für heruntergeladene Rohdaten
DATA_RAW_PATH=../data/raw

# Ordner für verarbeitete, normalisierte Daten
DATA_PROCESSED_PATH=../data/processed

# ------------------------------------------------------------
# Frontend – Vite (in frontend/.env)
# ------------------------------------------------------------
# Hinweis: Für das Frontend eine separate Datei frontend/.env anlegen.
# Vite-Variablen müssen mit VITE_ beginnen.
#
# Inhalt von frontend/.env:
# VITE_API_URL=http://localhost:8000/api/v1