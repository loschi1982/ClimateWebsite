# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Was ist diese Datei?
# Diese Datei ist eine VORLAGE für deine .env-Datei.
# Die .env-Datei enthält Passwörter, API-Schlüssel und Adressen
# die deine Anwendung braucht – aber NICHT in Git gespeichert werden.
#
# So verwendest du diese Datei:
#   1. Kopiere diese Datei und nenne die Kopie ".env":
#      Windows (Git Bash):  cp .env.example .env
#      macOS/Linux:         cp .env.example .env
#   2. Öffne .env und fülle die Werte aus (wo nötig)
#   3. Die .env-Datei NIEMALS in Git einchecken!
#      (sie steht bereits in .gitignore)
#
# Warum eine .env-Datei?
# Stell dir vor, dein API-Schlüssel wäre im Code:
#   NASA_API_KEY = "mein-geheimer-schlüssel"
# Wenn du den Code auf GitHub hochlädst, kann JEDER deinen Schlüssel sehen!
# Mit einer .env-Datei bleibt der Schlüssel nur auf deinem Computer.
#
# Team: Developer Setup Team | Branch: feature/developer-setup
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# DATENBANK
# ══════════════════════════════════════════════════════════════════════════════

# Was ist DATABASE_URL?
# Diese Variable sagt dem Backend wo die Datenbank läuft.
# Format: postgresql://BENUTZER:PASSWORT@HOST:PORT/DATENBANKNAME
#
# Für lokale Entwicklung mit Docker Compose (Standard):
#   "db" ist der Name des Datenbank-Containers (Docker löst das automatisch auf)
DATABASE_URL=postgresql://climateinsight:password@db:5432/climateinsight

# Was ist DATABASE_URL_DIRECT?
# Wenn du direkt (ohne Docker) auf die Datenbank zugreifen willst,
# z.B. mit einem Datenbank-Tool wie DBeaver oder pgAdmin.
# "localhost" statt "db", weil du von deinem Computer aus zugreifst.
DATABASE_URL_DIRECT=postgresql://climateinsight:password@localhost:5432/climateinsight

# Datenbank-Zugangsdaten (werden von docker-compose.yml verwendet)
# Diese müssen mit den Werten in docker-compose.yml übereinstimmen!
POSTGRES_USER=climateinsight
POSTGRES_PASSWORD=password
POSTGRES_DB=climateinsight


# ══════════════════════════════════════════════════════════════════════════════
# REDIS (Cache)
# ══════════════════════════════════════════════════════════════════════════════

# Was ist REDIS_URL?
# Redis ist ein schneller Zwischenspeicher.
# Diese Variable sagt dem Backend wo Redis läuft.
# Format: redis://HOST:PORT/DATENBANK-NUMMER
# Die Datenbank-Nummer (hier: 0) trennt verschiedene Anwendungen
# die denselben Redis nutzen.
REDIS_URL=redis://redis:6379/0

# Wie lange sollen Berechnungsergebnisse im Cache bleiben?
# 3600 Sekunden = 1 Stunde
REDIS_CACHE_TTL=3600


# ══════════════════════════════════════════════════════════════════════════════
# MINIO (Objektspeicher für große Dateien)
# ══════════════════════════════════════════════════════════════════════════════

# Was ist MINIO_ENDPOINT?
# MinIO ist unser lokaler Dateispeicher (wie Amazon S3).
# Hier werden große Klimadateien, Bilder und Exporte gespeichert.
MINIO_ENDPOINT=minio:9000

# Zugangsdaten für MinIO
MINIO_ROOT_USER=climateinsight
MINIO_ROOT_PASSWORD=password123

# Was ist MINIO_BUCKET_CLIMATE_DATA?
# Ein "Bucket" ist ein Ordner in MinIO.
# Wir verwenden separate Buckets für verschiedene Dateitypen.
MINIO_BUCKET_CLIMATE_DATA=climate-data      # Rohe Klimadaten (CSV, NetCDF)
MINIO_BUCKET_CHARTS=charts                  # Generierte Diagramm-Bilder
MINIO_BUCKET_EXPORTS=exports                # Exportierte Berichte (PDF)

# SSL für MinIO? (für lokale Entwicklung: false)
MINIO_USE_SSL=false


# ══════════════════════════════════════════════════════════════════════════════
# FASTAPI BACKEND
# ══════════════════════════════════════════════════════════════════════════════

# Was ist SECRET_KEY?
# Ein geheimer Schlüssel zum Verschlüsseln von Sitzungen und Tokens.
# WICHTIG: Ändere diesen Wert für die Produktion!
# Generiere einen sicheren Schlüssel mit:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production-please

# Was ist DEBUG?
# Im Debug-Modus zeigt FastAPI detaillierte Fehlermeldungen.
# true = Entwicklung, false = Produktion
DEBUG=true

# Was ist LOG_LEVEL?
# Wie detailliert sollen Log-Nachrichten sein?
# Optionen: debug, info, warning, error, critical
# "debug" zeigt ALLES – gut zum Entwickeln, aber sehr viel Output.
LOG_LEVEL=debug

# Auf welchem Host und Port soll das Backend laufen?
API_HOST=0.0.0.0
API_PORT=8000

# Was ist ALLOWED_ORIGINS?
# CORS (Cross-Origin Resource Sharing) bestimmt welche Webseiten
# das Backend aufrufen dürfen. Für Entwicklung erlauben wir localhost.
# Mehrere Adressen mit Komma trennen.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080


# ══════════════════════════════════════════════════════════════════════════════
# NEXT.JS FRONTEND
# ══════════════════════════════════════════════════════════════════════════════

# Was ist NEXT_PUBLIC_API_URL?
# Die Adresse des Backends – vom Browser aus gesehen.
# "NEXT_PUBLIC_" bedeutet: diese Variable ist im Browser sichtbar.
# Variablen ohne dieses Präfix sind NUR auf dem Server verfügbar.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Interne API-URL für Server-seitige Anfragen (Next.js → Backend)
# Hier können wir den Docker-internen Namen verwenden.
INTERNAL_API_URL=http://api_gateway:8000

# Next.js Konfiguration
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1   # Keine Nutzungsdaten an Vercel senden


# ══════════════════════════════════════════════════════════════════════════════
# KLIMADATEN API-SCHLÜSSEL
# ══════════════════════════════════════════════════════════════════════════════

# Was ist NASA_API_KEY?
# Die NASA erfordert einen API-Schlüssel für viele ihrer Dienste.
# Kostenlos registrieren unter: https://api.nasa.gov/
# Für Tests kannst du "DEMO_KEY" verwenden (stark limitiert!).
NASA_API_KEY=DEMO_KEY

# Was ist NOAA_API_TOKEN?
# NOAA (Nationale Ozean- und Atmosphärenbehörde) stellt Klimadaten bereit.
# Token kostenlos anfordern: https://www.ncdc.noaa.gov/cdo-web/token
# Für Tests leer lassen – einige Endpunkte sind ohne Token verfügbar.
NOAA_API_TOKEN=

# Was ist COPERNICUS_API_URL?
# Copernicus ist das Erdbeobachtungsprogramm der EU.
# Zugangsdaten registrieren: https://cds.climate.copernicus.eu/
COPERNICUS_API_URL=https://cds.climate.copernicus.eu/api/v2
COPERNICUS_API_KEY=

# Was ist NSIDC_API_URL?
# NSIDC = National Snow and Ice Data Center
# Liefert Daten zu Meereis und Gletschern.
# Viele Daten sind ohne API-Schlüssel verfügbar.
NSIDC_API_URL=https://nsidc.org/api/


# ══════════════════════════════════════════════════════════════════════════════
# AI / ANTHROPIC
# ══════════════════════════════════════════════════════════════════════════════

# Was ist ANTHROPIC_API_KEY?
# Das AI Explanation Team verwendet Claude (von Anthropic) um
# wissenschaftliche Klimaerklärungen zu generieren.
# API-Schlüssel erstellen: https://console.anthropic.com/
# WICHTIG: Gib diesen Schlüssel NIEMALS weiter oder committe ihn!
ANTHROPIC_API_KEY=

# Welches Claude-Modell verwenden?
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximale Tokens pro Generierungsanfrage
ANTHROPIC_MAX_TOKENS=4096


# ══════════════════════════════════════════════════════════════════════════════
# E-MAIL (für Benachrichtigungen)
# ══════════════════════════════════════════════════════════════════════════════

# Was ist SMTP_HOST?
# SMTP ist das Protokoll zum Versenden von E-Mails.
# Für lokale Entwicklung verwenden wir MailHog (Port 1025).
# MailHog fängt alle E-Mails ab statt sie wirklich zu versenden.
SMTP_HOST=mailhog        # Docker-Service-Name
SMTP_PORT=1025           # MailHog SMTP Port
SMTP_USER=               # Leer für MailHog
SMTP_PASSWORD=           # Leer für MailHog
EMAIL_FROM=noreply@climateinsight.dev


# ══════════════════════════════════════════════════════════════════════════════
# ENTWICKLUNGS-UTILITIES
# ══════════════════════════════════════════════════════════════════════════════

# Was ist SEED_DATABASE?
# Wenn "true": Beim Start werden Beispieldaten in die Datenbank geladen.
# Nützlich für Entwicklung und Tests.
# In der Produktion immer "false"!
SEED_DATABASE=true

# Was ist RESET_DATABASE?
# Wenn "true": Beim Start wird die Datenbank gelöscht und neu erstellt.
# VORSICHT: Alle Daten gehen verloren!
# Nur für Entwicklung – niemals in der Produktion!
RESET_DATABASE=false