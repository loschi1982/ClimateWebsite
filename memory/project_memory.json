  "architecture_decisions": [
    {
      "id": "adr_001",
      "timestamp": "2026-03-05T10:00:00Z",
      "team": "system_architect",
      "topic": "Datenbankwahl für Zeitreihen",
      "decision": "TimescaleDB als primäre Zeitreihendatenbank",
      "reasoning": "Klimadaten sind primär Zeitreihendaten. TimescaleDB bietet 10-100x bessere Performance als plain PostgreSQL und unterstützt gleichzeitig relationale Verknüpfungen.",
      "alternatives_considered": ["InfluxDB", "QuestDB", "plain PostgreSQL"],
      "impact": ["data_pipeline_team", "climate_analysis_team", "visualization_team"],
      "status": "accepted"
    },
    {
      "id": "adr_002",
      "timestamp": "2026-03-05T10:00:00Z",
      "team": "system_architect",
      "topic": "Frontend-Framework",
      "decision": "Next.js 15 mit App Router und TypeScript",
      "reasoning": "SSR für SEO, TypeScript für Typsicherheit im Multi-Team-Betrieb, App Router für moderne Datenladestrategien.",
      "alternatives_considered": ["Vue.js + Nuxt", "SvelteKit", "React SPA"],
      "impact": ["frontend_team", "ux_team"],
      "status": "accepted"
    },
    {
      "id": "adr_003",
      "timestamp": "2026-03-05T10:00:00Z",
      "team": "system_architect",
      "topic": "KI-Artikel-Workflow",
      "decision": "Kein generierter Artikel wird ohne menschliche Prüfung veröffentlicht",
      "reasoning": "Wissenschaftliche Plattform — automatische Veröffentlichung würde die Glaubwürdigkeit gefährden. Status 'pending_review' ist Pflicht.",
      "alternatives_considered": ["Automatische Veröffentlichung mit Confidence-Score"],
      "impact": ["ai_explanation_team", "frontend_team"],
      "status": "accepted",
      "non_negotiable": true
    },
    {
      "id": "adr_004",
      "timestamp": "2026-03-05T10:00:00Z",
      "team": "system_architect",
      "topic": "API-Versionierung",
      "decision": "URL-Pfad-Versionierung (/api/v1/)",
      "reasoning": "Einfach, explizit, keine Header-Magie. Teams können v1 stabil halten während v2 entwickelt wird.",
      "impact": ["all_teams"],
      "status": "accepted"
    },
    {
      "id": "adr_005",
      "timestamp": "2026-03-05T10:00:00Z",
      "team": "system_architect",
      "topic": "Simulationsort (client vs. server)",
      "decision": "OFFEN — noch nicht entschieden",
      "reasoning": "Server-seitig ist zuverlässiger, client-seitig (WASM) ermöglicht Echtzeit-Interaktion. Simulation Team und Frontend Team müssen gemeinsam entscheiden.",
      "impact": ["simulation_team", "frontend_team"],
      "status": "open"
    }
  ],

